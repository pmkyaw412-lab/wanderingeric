---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import YouTube from '../../components/YouTube.astro';
import {
  getFeed,
  SEGMENT,
  LABEL,
  hrefFor,
  fmtDateLong,
  readingTime,
  type FeedEntry,
} from '../../lib/feed';

export async function getStaticPaths() {
  const feed = await getFeed();
  return feed.map((entry) => {
    const siblings = feed.filter((e) => e.data.type === entry.data.type);
    const idx = siblings.findIndex((e) => e.id === entry.id);
    return {
      params: { segment: SEGMENT[entry.data.type], slug: entry.id },
      props: {
        entry,
        prev: siblings[idx + 1] ?? null, // older
        next: siblings[idx - 1] ?? null, // newer
      },
    };
  });
}

interface Props {
  entry: FeedEntry;
  prev: FeedEntry | null;
  next: FeedEntry | null;
}

const { entry, prev, next } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const description =
  'description' in data && data.description
    ? data.description
    : `${data.title} — ${LABEL[data.type]} on Wandering Eric.`;

const metaBits: string[] = [fmtDateLong(data.date)];
if (data.type === 'vlog') {
  if (data.location) metaBits.push(data.location);
  if (data.duration) metaBits.push(data.duration);
}
if (data.type === 'writing') metaBits.push(readingTime(entry.body));
if (data.type === 'project') {
  if (data.tech) metaBits.push(data.tech);
  if (data.status) metaBits.push(data.status);
}
if (data.type === 'reading') metaBits.push(`by ${data.author}`, data.status);
if (data.type === 'hobby' && data.meta) metaBits.push(data.meta);
---

<Base title={data.title} description={description}>
  <article class="article">
    <a class="backlink" href="/#lately">← back to the garden</a>
    <span class="tag">{LABEL[data.type]}</span>
    <h1>{data.title}</h1>
    <p class="meta-row">
      {metaBits.map((bit, i) => (
        <>
          {i > 0 && <span aria-hidden="true">·</span>}
          <span>{bit}</span>
        </>
      ))}
    </p>
    <div class="seam" aria-hidden="true"></div>

    {data.type === 'vlog' && <YouTube id={data.youtube} title={data.title} />}

    {
      data.type === 'project' && data.link && (
        <p class="prose" style="margin-bottom:26px">
          <a href={data.link}>Visit the project ↗</a>
        </p>
      )
    }

    <div class="prose">
      <Content />
    </div>

    {
      (prev || next) && (
        <nav class="pn" aria-label={`More ${LABEL[data.type].toLowerCase()} entries`}>
          {prev ? (
            <a href={hrefFor(prev)}>
              <span class="dir">← Older</span>
              <span class="t">{prev.data.title}</span>
            </a>
          ) : (
            <span />
          )}
          {next && (
            <a class="next" href={hrefFor(next)}>
              <span class="dir">Newer →</span>
              <span class="t">{next.data.title}</span>
            </a>
          )}
        </nav>
      )
    }
  </article>
</Base>
