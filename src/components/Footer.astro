---
import { SITE, SOCIALS } from '../config';
---

<footer class="site-foot">
  <div class="wrap foot-inner">
    <div>
      <div class="foot-brand"><span class="dot" aria-hidden="true"></span>{SITE.name}</div>
      <div class="foot-sig">{SITE.signOff}</div>
    </div>
    <nav class="socials" aria-label="Elsewhere">
      {SOCIALS.map((s) => <a href={s.href}>{s.label} ↗</a>)}
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>
